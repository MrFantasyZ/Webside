PORT=5000
MONGODB_URI=mongodb://localhost:27017/ai-video-store
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# 阿里云号码认证服务（短信验证码）
# AccessKey：https://ram.console.aliyun.com/manage/ak
ALIYUN_ACCESS_KEY_ID=your-aliyun-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
# 签名名称：在号码认证控制台「赠送签名配置」页面获取（如：速通互联验证码）
ALIYUN_SMS_SIGN_NAME=your-sign-name
# 模板CODE：在号码认证控制台「赠送模板配置」页面获取（如：100001）
ALIYUN_SMS_TEMPLATE_CODE=your-template-code

# Payment Configuration (Alipay/WeChat Pay)
ALIPAY_APP_ID=your-alipay-app-id
ALIPAY_PRIVATE_KEY=your-alipay-private-key
ALIPAY_PUBLIC_KEY=alipay-public-key

WECHAT_APP_ID=your-wechat-app-id
WECHAT_MCH_ID=your-wechat-mch-id
WECHAT_API_KEY=your-wechat-api-key

# File Upload Configuration
UPLOAD_PATH=uploads/
MAX_FILE_SIZE=100MB